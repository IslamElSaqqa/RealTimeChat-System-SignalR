@{
    ViewData["Title"] = "Advanced Chat";
    // Full-screen app view: use the dedicated chat layout, not the shared
    // site _Layout. The shared layout's absolutely-positioned footer
    // overlapped the bottom of .chat-container (right where the message
    // input and Send button are), silently blocking clicks/typing there.
    Layout = "_ChatLayout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    html, body {
        height: 100%;
    }

    .chat-container {
        height: 90vh;
    }

    .rooms {
        background: #f8f9fa;
        overflow: auto;
    }

    .messages {
        overflow: auto;
        background: white;
    }

    .users {
        background: #f8f9fa;
        overflow: auto;
    }

    .message-box {
        height: 65vh;
        overflow: auto;
        padding: 15px;
        border: 1px solid #dee2e6;
    }

    .room-item {
        cursor: pointer;
        padding: 8px;
        border-radius: 4px;
        transition: all 0.2s;
    }

        .room-item:hover {
            background-color: #e9ecef;
        }

        .room-item.active {
            background-color: #0d6efd;
            color: white;
        }

    .room-controls {
        display: flex;
        gap: 5px;
        font-size: 12px;
    }

        .room-controls button {
            padding: 2px 5px;
            font-size: 11px;
        }

    .message-item {
        margin-bottom: 10px;
        padding: 8px;
        background-color: #f0f0f0;
        border-radius: 4px;
        border-left: 3px solid #0d6efd;
    }

    .message-sender {
        font-weight: bold;
        color: #0d6efd;
    }

    .message-time {
        font-size: 12px;
        color: #999;
    }

    .room-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    #newRoomName {
        font-size: 14px;
        padding: 5px;
    }

    .btn-sm-custom {
        padding: 4px 8px;
        font-size: 12px;
    }

</style>

<div class="container-fluid">

    <div class="row chat-container">

        <div class="col-2 rooms">

            <h5 class="mt-3">Rooms</h5>

            <div class="mb-2">
                <div class="input-group input-group-sm mb-2">
                    <input id="newRoomName"
                           class="form-control"
                           type="text"
                           placeholder="New room name" />
                </div>
                <button id="btnCreateRoom"
                        class="btn btn-success btn-sm w-100">
                    Create Room
                </button>
            </div>

            <hr />

            <ul id="roomList"
                class="list-group">
            </ul>

        </div>

        <div class="col-8 d-flex flex-column">

            <div class="room-header">
                <h3 class="text-center flex-grow-1 mt-2">
                    <span id="currentRoomName">Advanced Chat</span>
                </h3>
            </div>

            <hr />

            <div id="messages"
                 class="message-box">
            </div>

            <div class="mt-auto">

                <div class="input-group">

                    <input id="txtMessage"
                           class="form-control"
                           placeholder="Type a message..." />

                    <button id="btnSend"
                            class="btn btn-primary">

                        Send

                    </button>

                </div>

            </div>

        </div>

        <div class="col-2 users">

            <h5 class="mt-3">

                Online Users

            </h5>

            <ul id="onlineUsers"
                class="list-group">
            </ul>

        </div>

    </div>

</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>

    // State Management
    let currentRoom = null;
    let currentRoomName = "";

    // The JWT lives server-side in Session (set by AuthController.Login).
    // ChatController.Index() reads it out of Session and renders it here so
    // the browser can seed localStorage with it. Without this, token was
    // always null and every authenticated call (REST + SignalR) failed.
    const serverToken = "@Html.Raw(ViewBag.Token)";
    if (serverToken) {
    localStorage.setItem("token", serverToken);
    }
    let token = localStorage.getItem("token");

    if (!token) {
    // Safety net: no token anywhere means the session expired mid-page.
    window.location.href = "/Auth/Login";
    }

    let rooms = [];

    const connection = new signalR.HubConnectionBuilder()
    .withUrl("https://localhost:7127/chatHub", {
    accessTokenFactory: () => token
    })
    .withAutomaticReconnect()
    .build();

    // API Calls
    async function loadRooms() {
    try {
    const response = await fetch("https://localhost:7127/api/rooms", {
    method: "GET",
    headers: {
    "Authorization": `Bearer ${token}`,
    "Content-Type": "application/json"
    }
    });

    if (!response.ok) {
    console.error("Failed to load rooms:", response.status);
    return;
    }

    rooms = await response.json();
    displayRooms();
    } catch (error) {
    console.error("Error loading rooms:", error);
    }
    }

    async function createRoom(roomName) {

    if (!roomName.trim()) {
    alert("Please enter a room name");
    return;
    }

    try {

    const response = await fetch("https://localhost:7127/api/rooms", {
    method: "POST",
    headers: {
    "Authorization": `Bearer ${token}`,
    "Content-Type": "application/json"
    },
    // The API's CreateRoom endpoint binds [FromBody] ClreateRoomDTO,
    // which expects a JSON object with a "roomName" property - not
    // a bare JSON string. Sending JSON.stringify(roomName) used to
    // post "someName" (a raw string literal), which the model
    // binder silently ignored, leaving RoomName null/empty.
    body: JSON.stringify({ roomName: roomName })
    });

    if (!response.ok) {

    const error = await response.text();

    alert(error);

    return;
    }

    document.getElementById("newRoomName").value = "";

    // DO NOT:
    // rooms.push(...)
    // displayRooms()
    // connection.invoke("CreateRoom")

    // The SignalR RoomCreated event will update every client automatically.

    }
    catch (error) {

    console.error(error);

    alert("Error creating room");

    }

    }
    async function deleteRoom(roomId) {
    if (!confirm("Are you sure you want to delete this room?")) {
    return;
    }

    try {
    const response = await fetch(`https://localhost:7127/api/rooms/${roomId}`, {
    method: "DELETE",
    headers: {
    "Authorization": `Bearer ${token}`
    }
    });

    if (!response.ok) {
    console.error("Failed to delete room:", response.status);
    alert("Failed to delete room");
    return;
    }

    // Wait for SignalR RoomDeleted event.

    } catch (error) {
    console.error("Error deleting room:", error);
    alert("Error deleting room");
    }
    }
    async function loadPreviousMessages(roomId) {
    try {
    const response = await fetch(`https://localhost:7127/api/messages/room/${roomId}`, {
    method: "GET",
    headers: {
    "Authorization": `Bearer ${token}`,
    "Content-Type": "application/json"
    }
    });

    if (!response.ok) {
    console.error("Failed to load messages:", response.status);
    return;
    }

    const messages = await response.json();
    clearMessages();
    messages.forEach(msg => displayMessage(msg.sender, msg.content, msg.sentAt));
    } catch (error) {
    console.error("Error loading previous messages:", error);
    }
    }

    // UI Functions
    function displayRooms() {
    const roomList = document.getElementById("roomList");
    roomList.innerHTML = "";

    rooms.forEach(room => {
    const li = document.createElement("li");
    li.className = "list-group-item room-item";

    if (currentRoom === room.id) {
    li.classList.add("active");
    }

    li.innerHTML = `
    <div class="d-flex justify-content-between align-items-center">
    <span style="flex-grow: 1; cursor: pointer;">${room.name}</span>
    <div class="room-controls">
    <button class="btn btn-danger btn-sm-custom" onclick="deleteRoom('${room.id}')">
    Del
    </button>
    </div>
    </div>
    `;

    li.addEventListener("click", (e) => {
    if (!e.target.closest(".room-controls")) {
    selectRoom(room.id, room.name);
    }
    });

    roomList.appendChild(li);
    });
    }

    function selectRoom(roomId, roomName) {

    currentRoom = roomId;
    currentRoomName = roomName;

    displayRooms();

    document.getElementById("currentRoomName").textContent = roomName;

    clearMessages();

    loadPreviousMessages(roomId);

    connection.invoke("JoinRoom", roomId)
    .catch(err => console.error(err));

    }
    function displayMessage(sender, message, time) {
    const messagesDiv = document.getElementById("messages");
    const messageDiv = document.createElement("div");
    messageDiv.className = "message-item";

    const sentTime = new Date(time).toLocaleTimeString();
    messageDiv.innerHTML = `
    <div class="message-sender">${sender}</div>
    <div>${message}</div>
    <div class="message-time">${sentTime}</div>
    `;

    messagesDiv.appendChild(messageDiv);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function clearMessages() {
    const messagesDiv = document.getElementById("messages");
    messagesDiv.innerHTML = "";
    }

    // SignalR Connection
    connection.start()
    .then(() => {
    console.log("Connected to SignalR Hub");
    loadRooms();
    })
    .catch(err => console.error("Connection failed:", err));

    // SignalR Event Handlers
    connection.on("ReceiveRoomMessage", function (user, message, time) {
    if (currentRoom) {
    displayMessage(user, message, time);
    }
    });

    connection.on("OnlineUsers", function (users) {
    const onlineUsersList = document.getElementById("onlineUsers");
    onlineUsersList.innerHTML = "";

    users.forEach(function (user) {
    const li = document.createElement("li");
    li.className = "list-group-item";
    li.textContent = user;
    onlineUsersList.appendChild(li);
    });
    });

    connection.on("RoomCreated", function () {
    loadRooms();
    });

    connection.on("RoomDeleted", function (roomId) {

    if (currentRoom === roomId) {

    currentRoom = null;

    currentRoomName = "";

    clearMessages();

    document.getElementById("currentRoomName").textContent = "Advanced Chat";
    }

    loadRooms();

    });
    connection.on("UserJoined", function (userId) {
    if (currentRoom) {
    console.log(`${userId} joined the room`);
    }
    });

    connection.on("UserLeft", function (userId) {
    if (currentRoom) {
    console.log(`${userId} left the room`);
    }
    });

    connection.on("RoomMessagesLoaded", function (messages) {
    clearMessages();
    messages.forEach(msg => displayMessage(msg.sender, msg.content, msg.sentAt));
    });

    // Event Listeners
    document.getElementById("btnCreateRoom").addEventListener("click", function () {
    const roomName = document.getElementById("newRoomName").value;
    createRoom(roomName);
    });

    document.getElementById("newRoomName").addEventListener("keypress", function (e) {
    if (e.key === "Enter") {
    const roomName = document.getElementById("newRoomName").value;
    createRoom(roomName);
    }
    });

    document.getElementById("btnSend").addEventListener("click", function () {
    if (!currentRoom) {
    alert("Please select a room first");
    return;
    }

    const msg = document.getElementById("txtMessage").value;

    if (!msg.trim()) {
    alert("Message cannot be empty");
    return;
    }

    connection.invoke(
    "SendRoomMessage",
    currentRoom,
    msg)
    .catch(err => console.error(err));

    document.getElementById("txtMessage").value = "";
    });

    document.getElementById("txtMessage").addEventListener("keypress", function (e) {
    if (e.key === "Enter") {
    document.getElementById("btnSend").click();
    }
    });

</script>